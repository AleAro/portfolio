---
const experiences = [
  {
    title: "Software Engineer I",
    company: "Past Post",
    location: "Remote",
    period: "08/2022 – Present",
    bullets: [
      "Develop and launch iOS & Android applications with a focus on front-end development.",
      "Implement and enhance backend services on AWS (Lambda, API Gateway, DynamoDB), improving reliability and scalability.",
      "Analyze user feedback and performance metrics to drive continuous product improvements.",
    ],
    technologies: ["React Native", "Flutter", "AWS Lambda", "DynamoDB", "API Gateway", "TypeScript"],
  },
  {
    title: "Software Engineer Intern",
    company: "TeachersPro",
    location: "Madrid, Spain",
    period: "08/2024 – 01/2025",
    bullets: [
      "Migrated a production web platform to a mobile environment, ensuring performance, usability, and feature parity.",
      "Collaborated with designers and backend engineers to deliver a stable mobile release.",
    ],
    technologies: ["React Native", "JavaScript", "REST APIs"],
  },
  {
    title: "BPM & Continuous Improvement Intern",
    company: "Hellmann Worldwide Logistics",
    location: "Mexico City, MX (Remote)",
    period: "03/2021 – 07/2021",
    bullets: [
      "Developed and implemented standardized procedures to streamline business process management and optimize operational workflows.",
      "Analyzed key performance metrics to identify areas for efficiency and cost reduction.",
    ],
    technologies: ["Process Modeling", "KPI Analysis", "Documentation"],
  },
];
---

<section id="experience" class="py-28 bg-surface relative">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">

    <div class="mb-16 reveal">
      <span class="font-mono text-xs tracking-[0.2em] text-primary uppercase mb-2 block">Where I've Worked</span>
      <h2 class="font-headline text-4xl md:text-5xl font-extrabold tracking-tight text-text-primary">Experience</h2>
    </div>

    <div class="space-y-6">
      {experiences.map((exp) => (
        <div class="reveal group bg-surface-high border border-outline/10 hover:border-primary/20 rounded-2xl p-8 transition-all duration-300">
          <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4 mb-5">
            <div>
              <h3 class="font-headline text-xl font-bold text-text-primary group-hover:text-primary transition-colors duration-200 mb-1">
                {exp.title}
              </h3>
              <p class="font-mono text-sm text-primary">{exp.company}</p>
            </div>
            <div class="flex flex-col lg:items-end gap-1">
              <span class="font-mono text-xs text-text-secondary tracking-wider">{exp.period}</span>
              <span class="font-mono text-xs text-outline">{exp.location}</span>
            </div>
          </div>

          <ul class="space-y-2 mb-6">
            {exp.bullets.map((b) => (
              <li class="flex gap-3 text-text-secondary text-sm leading-relaxed">
                <span class="text-primary mt-1 flex-shrink-0">›</span>
                <span>{b}</span>
              </li>
            ))}
          </ul>

          <div class="flex flex-wrap gap-2">
            {exp.technologies.map((tech) => (
              <span class="px-3 py-1 bg-surface border border-outline/20 text-text-secondary rounded-md text-[11px] font-mono uppercase tracking-widest">
                {tech}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

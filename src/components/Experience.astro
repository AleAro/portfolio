---
import { Briefcase, Calendar, MapPin } from 'phosphor-react';

const experiences = [
  {
    title: "Software Developer Intern",
    company: "Tech Company",
    location: "Mexico",
    period: "2023 - 2024",
    description: "Developed and maintained web applications using modern technologies. Collaborated with cross-functional teams to deliver high-quality software solutions.",
    technologies: ["JavaScript", "React", "Node.js", "Python"]
  },
  {
    title: "Research Assistant",
    company: "Tecnológico de Monterrey",
    location: "Mexico",
    period: "2022 - 2023",
    description: "Conducted research on data accessibility and technology solutions. Contributed to academic papers and presented findings at conferences.",
    technologies: ["Python", "Data Analysis", "Machine Learning", "Research"]
  },
  {
    title: "Freelance Developer",
    company: "Independent",
    location: "Remote",
    period: "2021 - 2022",
    description: "Built custom web solutions for small businesses. Focused on creating user-friendly interfaces and efficient backend systems.",
    technologies: ["HTML/CSS", "JavaScript", "PHP", "MySQL"]
  }
];
---

<section id="experience" class="py-24 bg-slate-900">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 reveal">
      <h2 class="text-4xl md:text-5xl font-bold mb-6 text-gradient">
        <span class="font-mono text-teal-400 text-lg">02.</span> Experience
      </h2>
      <p class="text-xl text-slate-400 max-w-3xl mx-auto leading-relaxed">
        My professional journey and the experiences that have shaped my development as a software engineer.
      </p>
    </div>

    <div class="space-y-8">
      {experiences.map((exp, index) => (
        <div class="reveal bg-slate-800/30 backdrop-blur-sm p-8 rounded-2xl border border-slate-700/50 hover:border-slate-600/50 transition-all duration-300 group">
          <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between mb-6">
            <div>
              <h3 class="text-2xl font-bold mb-2 text-white group-hover:text-teal-400 transition-colors duration-200">
                {exp.title}
              </h3>
              <p class="text-lg text-teal-400 font-semibold">{exp.company}</p>
            </div>
            <div class="flex flex-col lg:items-end mt-4 lg:mt-0">
              <span class="text-slate-300 font-mono text-sm mb-1">
                {exp.period}
              </span>
              <span class="text-slate-400 text-sm">
                {exp.location}
              </span>
            </div>
          </div>
          
          <p class="text-slate-300 mb-6 leading-relaxed text-lg">
            {exp.description}
          </p>
          
          <div class="flex flex-wrap gap-3">
            {exp.technologies.map((tech) => (
              <span class="px-4 py-2 bg-slate-700/50 text-slate-300 rounded-full text-sm font-medium hover:bg-slate-600/50 transition-colors duration-200">
                {tech}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
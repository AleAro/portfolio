---
import { Envelope, Phone, MapPin, LinkedinLogo, GithubLogo, TwitterLogo } from 'phosphor-react';
---

<section id="contact" class="py-20 bg-slate-800/50">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Get In Touch</h2>
      <p class="text-slate-300 max-w-2xl mx-auto">
        Interested in collaborating or discussing how we can make technology more accessible? I'd love to hear from you.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-12">
      <!-- Contact Information -->
      <div class="space-y-8">
        <div>
          <h3 class="text-xl font-semibold mb-6">Let's Connect</h3>
          <div class="space-y-4">
            <div class="flex items-center gap-4">
              <div class="bg-blue-500/20 p-3 rounded-lg">
                <Envelope size={24} className="text-blue-400" />
              </div>
              <div>
                <p class="font-medium">Email</p>
                <p class="text-slate-300">alejandro.arouesty@example.com</p>
              </div>
            </div>
            
            <div class="flex items-center gap-4">
              <div class="bg-green-500/20 p-3 rounded-lg">
                <Phone size={24} className="text-green-400" />
              </div>
              <div>
                <p class="font-medium">Phone</p>
                <p class="text-slate-300">+52 (555) 123-4567</p>
              </div>
            </div>
            
            <div class="flex items-center gap-4">
              <div class="bg-purple-500/20 p-3 rounded-lg">
                <MapPin size={24} className="text-purple-400" />
              </div>
              <div>
                <p class="font-medium">Location</p>
                <p class="text-slate-300">Mexico</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Social Links -->
        <div>
          <h3 class="text-xl font-semibold mb-6">Follow Me</h3>
          <div class="flex gap-4">
            <a href="#" class="bg-slate-800 hover:bg-blue-600 p-3 rounded-lg transition-colors duration-200">
              <LinkedinLogo size={20} />
            </a>
            <a href="#" class="bg-slate-800 hover:bg-gray-600 p-3 rounded-lg transition-colors duration-200">
              <GithubLogo size={20} />
            </a>
            <a href="#" class="bg-slate-800 hover:bg-blue-500 p-3 rounded-lg transition-colors duration-200">
              <TwitterLogo size={20} />
            </a>
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="bg-slate-800 p-8 rounded-xl">
        <form class="space-y-6">
          <div>
            <label for="name" class="block text-sm font-medium mb-2">Name</label>
            <input 
              type="text" 
              id="name" 
              name="name"
              class="w-full px-4 py-3 bg-slate-700 border border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200"
              placeholder="Your Name"
            />
          </div>
          
          <div>
            <label for="email" class="block text-sm font-medium mb-2">Email</label>
            <input 
              type="email" 
              id="email" 
              name="email"
              class="w-full px-4 py-3 bg-slate-700 border border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200"
              placeholder="your.email@example.com"
            />
          </div>
          
          <div>
            <label for="message" class="block text-sm font-medium mb-2">Message</label>
            <textarea 
              id="message" 
              name="message" 
              rows="5"
              class="w-full px-4 py-3 bg-slate-700 border border-slate-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200 resize-none"
              placeholder="Tell me about your project or how we can collaborate..."
            ></textarea>
          </div>
          
          <button 
            type="submit"
            class="w-full bg-gradient-to-r from-blue-500 to-purple-600 hover:from-blue-600 hover:to-purple-700 px-8 py-3 rounded-lg font-semibold transition-all duration-200 transform hover:scale-105"
          >
            Send Message
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
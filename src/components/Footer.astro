<footer class="bg-background border-t border-outline/10 py-14 px-6 lg:px-12">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-8">

    <div>
      <div class="font-headline font-black text-text-primary text-lg tracking-tight uppercase mb-1">
        Alejandro Arouesty
      </div>
      <p class="font-mono text-[10px] tracking-widest uppercase text-text-secondary">
        Software Engineer · Mexico City, MX
      </p>
    </div>

    <nav class="flex flex-wrap justify-center gap-6">
      {["about", "experience", "projects", "contact"].map((link) => (
        <a
          href={`#${link}`}
          class="font-mono text-[10px] tracking-widest uppercase text-text-secondary hover:text-primary transition-colors duration-200 capitalize"
        >
          {link}
        </a>
      ))}
    </nav>

    <p class="font-mono text-[10px] tracking-widest uppercase text-outline">
      © {new Date().getFullYear()} Alejandro Arouesty Galvan

---
import { Code, Download, ArrowRight } from 'phosphor-react';
---

<section id="home" class="min-h-screen flex items-center justify-center pt-16">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div class="animate-fade-in">
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold mb-6">
        Hi, I'm <span class="bg-gradient-to-r from-blue-400 to-purple-500 bg-clip-text text-transparent">Alejandro</span>
      </h1>
      <p class="text-xl md:text-2xl text-slate-300 mb-8 max-w-3xl mx-auto">
        Software developer recently graduated from Tecnológico de Monterrey that tries to make data and technology more accessible to everyone.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="#projects" 
          class="bg-gradient-to-r from-blue-500 to-purple-600 hover:from-blue-600 hover:to-purple-700 px-8 py-3 rounded-lg font-semibold transition-all duration-200 transform hover:scale-105 flex items-center justify-center gap-2"
        >
          <Code size={20} />
          View My Work
        </a>
        <a 
          href="/cv-alejandro-arouesty.pdf" 
          target="_blank"
          class="border border-slate-600 hover:border-blue-400 px-8 py-3 rounded-lg font-semibold transition-all duration-200 hover:bg-slate-800 flex items-center justify-center gap-2"
        >
          <Download size={20} />
          Download CV
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fade-in 1s ease-out;
  }
</style>
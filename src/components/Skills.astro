---
import { 
  Code, 
  Database, 
  Globe, 
  DeviceMobile, 
  ChartBar, 
  GitBranch,
  CloudArrowUp,
  Cpu,
  Terminal,
  Palette,
  Brain,
  Gear
} from 'phosphor-react';

const skillCategories = [
  {
    title: "Programming Languages",
    icon: Code,
    skills: [
      { name: "JavaScript", level: 90 },
      { name: "Python", level: 85 },
      { name: "Java", level: 80 },
      { name: "TypeScript", level: 85 },
      { name: "C++", level: 75 },
      { name: "SQL", level: 80 }
    ]
  },
  {
    title: "Web Development",
    icon: Globe,
    skills: [
      { name: "React", level: 90 },
      { name: "Node.js", level: 85 },
      { name: "HTML/CSS", level: 95 },
      { name: "Vue.js", level: 75 },
      { name: "Express.js", level: 80 },
      { name: "Astro", level: 70 }
    ]
  },
  {
    title: "Data & Analytics",
    icon: ChartBar,
    skills: [
      { name: "Data Analysis", level: 85 },
      { name: "Machine Learning", level: 75 },
      { name: "Pandas", level: 80 },
      { name: "NumPy", level: 80 },
      { name: "Matplotlib", level: 75 },
      { name: "Jupyter", level: 85 }
    ]
  },
  {
    title: "Tools & Technologies",
    icon: Gear,
    skills: [
      { name: "Git", level: 90 },
      { name: "Docker", level: 70 },
      { name: "AWS", level: 65 },
      { name: "MongoDB", level: 75 },
      { name: "PostgreSQL", level: 80 },
      { name: "Linux", level: 75 }
    ]
  }
];
---

<section class="py-24 bg-slate-800">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 reveal">
      <h2 class="text-4xl md:text-5xl font-bold mb-6 text-gradient">
        Skills & Technologies
      </h2>
      <p class="text-xl text-slate-400 max-w-3xl mx-auto leading-relaxed">
        The technologies and tools I use to bring ideas to life and make data more accessible.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      {skillCategories.map((category) => (
        <div class="reveal bg-slate-900/50 backdrop-blur-sm p-8 rounded-2xl border border-slate-700/50 hover:border-slate-600/50 transition-all duration-300">
          <div class="flex items-center gap-4 mb-8">
            <div class="p-3 bg-gradient-to-r from-teal-500 to-blue-500 rounded-xl">
              <category.icon size={28} className="text-white" />
            </div>
            <h3 class="text-2xl font-bold text-white">{category.title}</h3>
          </div>
          
          <div class="space-y-6">
            {category.skills.map((skill) => (
              <div class="group">
                <div class="flex justify-between items-center mb-3">
                  <span class="font-medium text-slate-200 group-hover:text-teal-400 transition-colors duration-200">{skill.name}</span>
                  <span class="text-sm text-slate-400 font-mono">{skill.level}%</span>
                </div>
                <div class="w-full bg-slate-700 rounded-full h-2 overflow-hidden">
                  <div 
                    class="bg-gradient-to-r from-teal-500 to-blue-500 h-2 rounded-full transition-all duration-1000 ease-out skill-bar"
                    style={`width: ${skill.level}%`}
                  ></div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .skill-bar {
    width: 0;
    animation: fillBar 1.5s ease-out forwards;
  }

  @keyframes fillBar {
    to {
      width: var(--skill-level);
    }
  }

  .reveal.animate-in .skill-bar {
    animation-play-state: running;
  }
</style>

<script>
  // Animate skill bars when they come into view
  const skillBars = document.querySelectorAll('.skill-bar');
  
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const bar = entry.target;
        const level = (bar as HTMLElement).style.width;
        (bar as HTMLElement).style.setProperty('--skill-level', level);
        (bar as HTMLElement).style.width = level;
      }
    });
  }, { threshold: 0.5 });

  skillBars.forEach(bar => observer.observe(bar));
</script>
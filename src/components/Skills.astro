const customDynamo = {
  slug: 'amazondynamodb',
  hex: '4053D6',
  path: 'M13.64 4.763c-.45-.285-1.103-.443-1.887-.443-.783 0-1.437.158-1.886.443L3.52 8.48v7.04l6.348 3.717c.449.285 1.103.443 1.886.443.784 0 1.437-.158 1.887-.443L20 15.52V8.48l-6.36-3.717zm-1.887.914c.598 0 1.08.12 1.362.293L18.643 9.3l-6.89 4.032-6.89-4.032 5.528-3.33c.282-.173.764-.293 1.362-.293zm-6.887 3.908 6.24 3.652v6.856l-5.65-3.308a.72.72 0 0 1-.27-.273.708.708 0 0 1-.098-.352v-5.575h-.222zm13.997 0v5.575a.708.708 0 0 1-.098.352.72.72 0 0 1-.27.273l-5.65 3.308v-6.856l6.018-3.652z',
};

const customAzure = {
  slug: 'microsoftazure',
  hex: '0078D4',
  path: 'M5.483 21.3H.45L11.753 2.682a.53.53 0 0 1 .917 0L23.55 21.3h-5.033l-6.544-11.37L5.483 21.3zm6.107-3.22 2.039-3.544H9.552l2.038 3.544z',
};

const customAmplify = {
  slug: 'awsamplify',
  hex: 'FF9900',
  path: 'M12 2L2 19.8h4.1l1.8-3.4H12v3.4h4.1L22 2H12zm0 3.4l4.4 8.6H12V5.4zm-2.4 9.6H7.5l2.1-4.1v4.1z',
};

// Icons whose brand color is black/near-black — override for dark background
const DARK_OVERRIDE: Record<string, string> = {
  vercel:     'FFFFFF',
  nextdotjs:  'FFFFFF',
  unity:      'FFFFFF',
  rust:       'CE422B',
};

const hoverColor = (icon: { slug: string; hex: string }) =>
  DARK_OVERRIDE[icon.slug] ?? icon.hex;

const categories = [
  {
    id: '01',
    title: 'Cloud & Infrastructure',
    skills: [
      { name: 'AWS',       icon: customAws },
      { name: 'DynamoDB',  icon: customDynamo },
      { name: 'Amplify',   icon: customAmplify },
      { name: 'Docker',    icon: siDocker },
      { name: 'Vercel',    icon: siVercel },
      { name: 'Git',       icon: siGit },
    ],
  },
  {
    id: '02',
    title: 'Data Architecture',
    skills: [
      { name: 'MongoDB',  icon: siMongodb },
      { name: 'MySQL',    icon: siMysql },
      { name: 'Neo4j',    icon: siNeo4j },
      { name: 'GraphQL',  icon: siGraphql },
    ],
  },
  {
    id: '03',
    title: 'Core Engineering',
    skills: [
      { name: 'JavaScript', icon: siJavascript },
      { name: 'TypeScript', icon: siTypescript },
      { name: 'Python',     icon: siPython },
      { name: 'C#',         icon: siDotnet },
      { name: 'Dart',       icon: siDart },
      { name: 'Node.js',    icon: siNodedotjs },
      { name: 'React',      icon: siReact },
      { name: 'Flutter',    icon: siFlutter },
      { name: 'Next.js',    icon: siNextdotjs },
      { name: 'Unity',      icon: siUnity },
    ],
  },
];

const learning = [
  { name: 'Kubernetes',   icon: siKubernetes },
  { name: 'Rust',         icon: siRust },
  { name: 'Google Cloud', icon: siGooglecloud },
  { name: 'Azure',        icon: customAzure },
];
---

<section class="py-28 bg-background">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">

    <!-- Header -->
    <div class="mb-16 reveal">
      <span class="font-mono text-xs tracking-[0.2em] text-primary uppercase mb-2 block">What I Build With</span>
      <h2 class="font-headline text-4xl md:text-5xl font-extrabold tracking-tight text-text-primary">Skills & Stack</h2>
    </div>

    <!-- Three-column category grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
      {categories.map((cat) => (
        <div class="reveal bg-surface-high border border-outline/10 hover:border-primary/20 rounded-2xl p-7 transition-all duration-300">

          <div class="flex items-center gap-2 mb-6">
            <span class="font-mono text-xs text-primary">{cat.id}</span>
            <h3 class="font-headline font-bold text-text-primary">{cat.title}</h3>
          </div>

          <div class="flex flex-col gap-2">
            {cat.skills.map((skill) => (
              <div
                class="skill-pill"
                style={`--brand: #${hoverColor(skill.icon)}`}
              >
                <svg
                  role="img"
                  viewBox="0 0 24 24"
                  xmlns="http://www.w3.org/2000/svg"
                  class="skill-icon"
                  aria-label={skill.name}
                >
                  <path d={skill.icon.path} />
                </svg>
                <span class="skill-name">{skill.name}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Learning section -->
    <div class="reveal bg-surface-high border border-outline/10 border-dashed rounded-2xl p-7">
      <div class="flex items-center gap-3 mb-6">
        <span class="font-mono text-xs text-secondary border border-secondary/30 px-2.5 py-0.5 rounded-full uppercase tracking-widest">Learning</span>
        <p class="text-text-secondary text-sm">Currently exploring</p>
      </div>
      <div class="flex gap-3 flex-wrap">
        {learning.map((skill) => (
          <div
            class="skill-pill skill-pill--lg"
            style={`--brand: #${hoverColor(skill.icon)}`}
          >
            <svg
              role="img"
              viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg"
              class="skill-icon skill-icon--lg"
              aria-label={skill.name}
            >
              <path d={skill.icon.path} />
            </svg>
            <span class="skill-name">{skill.name}</span>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  .skill-pill {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.5rem 0.75rem;
    border-radius: 0.625rem;
    border: 1px solid rgba(71, 71, 78, 0.2);
    color: var(--color-text-secondary);
    cursor: default;
    transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }

  .skill-pill:hover {
    color: var(--brand);
    border-color: color-mix(in srgb, var(--brand) 30%, transparent);
    background: color-mix(in srgb, var(--brand) 6%, transparent);
  }

  .skill-icon {
    width: 1rem;
    height: 1rem;
    fill: currentColor;
    flex-shrink: 0;
    transition: fill 0.2s ease;
  }

  .skill-name {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    transition: color 0.2s ease;
  }

  /* Larger variant for the Learning row */
  .skill-pill--lg {
    padding: 0.65rem 1rem;
  }

  .skill-icon--lg {
    width: 1.25rem;
    height: 1.25rem;
  }
</style>

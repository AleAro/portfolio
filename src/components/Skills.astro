---
const categories = [
  {
    id: "01",
    title: "Programming Languages",
    skills: ["JavaScript", "TypeScript", "Python", "C++", "Dart", "C#"],
  },
  {
    id: "02",
    title: "Frameworks & Mobile",
    skills: ["React Native", "Flutter", "Next.js", "React", "Node.js", "Express"],
  },
  {
    id: "03",
    title: "Cloud & Databases",
    skills: ["AWS Lambda", "API Gateway", "DynamoDB", "Amplify", "AppSync", "MongoDB", "SQL"],
  },
  {
    id: "04",
    title: "Tools & Other",
    skills: ["Git", "Unity (C#)", "Neo4j", "Three.js", "REST APIs", "JWT"],
  },
];
---

<section class="py-28 bg-background relative">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">

    <div class="mb-16 reveal">
      <span class="font-mono text-xs tracking-[0.2em] text-primary uppercase mb-2 block">What I Build With</span>
      <h2 class="font-headline text-4xl md:text-5xl font-extrabold tracking-tight text-text-primary">Skills & Stack</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {categories.map((cat) => (
        <div class="reveal bg-surface-high border border-outline/10 hover:border-primary/20 rounded-2xl p-8 transition-all duration-300 group">
          <div class="flex items-center gap-3 mb-6">
            <span class="font-mono text-xs text-primary">{cat.id}</span>
            <h3 class="font-headline font-bold text-text-primary text-lg">{cat.title}</h3>
          </div>
          <div class="flex flex-wrap gap-2">
            {cat.skills.map((skill) => (
              <span class="px-3.5 py-1.5 bg-surface border border-outline/20 hover:border-primary/30 hover:text-primary text-text-secondary rounded-lg text-xs font-mono uppercase tracking-widest transition-colors duration-200 cursor-default">
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Languages row -->
    <div class="reveal mt-6 bg-surface-high border border-outline/10 rounded-2xl p-8">
      <div class="flex items-center gap-3 mb-6">
        <span class="font-mono text-xs text-primary">05</span>
        <h3 class="font-headline font-bold text-text-primary text-lg">Spoken Languages</h3>
      </div>
      <div class="flex flex-wrap gap-4">
        {[
          { lang: "Spanish", level: "Native" },
          { lang: "English", level: "Fluent" },
          { lang: "German",  level: "Advanced" },
        ].map(({ lang, level }) => (
          <div class="flex items-center gap-3 bg-surface border border-outline/20 rounded-xl px-5 py-3">
            <span class="font-headline font-semibold text-text-primary">{lang}</span>
            <span class="font-mono text-[10px] tracking-widest uppercase text-primary border border-primary/30 px-2 py-0.5 rounded-full">{level}</span>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Quetzal Engine — Play in Browser">
  <div class="quetzal-shell">

    <!-- Top bar -->
    <header class="top-bar">
      <a href="/#projects" class="back-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 12H5"/><path d="m12 19-7-7 7-7"/>
        </svg>
        Back to Portfolio
      </a>
      <div class="top-bar-title">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-primary">
          <line x1="6" y1="12" x2="18" y2="12"/><line x1="6" y1="8" x2="18" y2="8"/><line x1="6" y1="16" x2="18" y2="16"/>
          <rect x="2" y="6" width="20" height="12" rx="2"/>
          <circle cx="16" cy="12" r="1" fill="currentColor"/>
          <circle cx="18" cy="10" r="1" fill="currentColor"/>
        </svg>
        Quetzal Engine
        <span class="top-bar-badge">Unity + Node.js + MySQL</span>
      </div>
    </header>

    <!-- Main area: iframe + sidebar -->
    <div class="stage">

      <!-- Game iframe -->
      <div class="game-frame-wrapper">
        <iframe
          src="https://alearo.github.io/Quetzal/Web/juego.html"
          title="Quetzal Engine — Playable Demo"
          allowfullscreen
          class="game-frame"
        ></iframe>
      </div>

      <!-- Technical sidebar -->
      <aside class="sidebar">
        <div class="sidebar-inner">

          <section class="sidebar-section">
            <h2 class="sidebar-heading">Architecture Overview</h2>
            <p class="sidebar-body">
              Quetzal Engine connects a Unity WebGL frontend to a persistent backend
              that tracks player state, inventory, and world events across sessions.
            </p>
          </section>

          <section class="sidebar-section">
            <div class="arch-badge">Frontend</div>
            <h3 class="sidebar-subheading">Unity WebGL</h3>
            <ul class="sidebar-list">
              <li>C# game logic compiled to WebAssembly via IL2CPP</li>
              <li>UnityWebRequest bridges game events to the REST API</li>
              <li>Player state is serialized and synced on scene transitions</li>
            </ul>
          </section>

          <section class="sidebar-section">
            <div class="arch-badge arch-badge--node">Backend</div>
            <h3 class="sidebar-subheading">Node.js REST API</h3>
            <ul class="sidebar-list">
              <li>Express.js server with JWT authentication middleware</li>
              <li>Route handlers for player sessions, inventory CRUD, and event logs</li>
              <li>Stateless design — each request is fully self-contained</li>
            </ul>
          </section>

          <section class="sidebar-section">
            <div class="arch-badge arch-badge--db">Persistence</div>
            <h3 class="sidebar-subheading">MySQL Database</h3>
            <ul class="sidebar-list">
              <li>Relational schema: <code>players</code>, <code>sessions</code>, <code>inventory</code>, <code>world_state</code></li>
              <li>Foreign key constraints enforce referential integrity</li>
              <li>Indexed on <code>player_id</code> + <code>session_token</code> for low-latency reads</li>
            </ul>
          </section>

          <section class="sidebar-section">
            <div class="arch-badge arch-badge--flow">Data Flow</div>
            <div class="flow">
              <div class="flow-step">Unity Client</div>
              <div class="flow-arrow">→ HTTP/JSON →</div>
              <div class="flow-step">Node.js API</div>
              <div class="flow-arrow">→ SQL queries →</div>
              <div class="flow-step">MySQL</div>
            </div>
          </section>

          <section class="sidebar-section">
            <h3 class="sidebar-subheading">Stack</h3>
            <div class="tag-row">
              <span class="tag">Unity 2022</span>
              <span class="tag">C#</span>
              <span class="tag">Node.js</span>
              <span class="tag">Express</span>
              <span class="tag">MySQL</span>
              <span class="tag">JWT</span>
              <span class="tag">WebAssembly</span>
            </div>
          </section>

        </div>
      </aside>
    </div>
  </div>
</Layout>

<style>
  /* Reset body padding for this full-screen page */
  :global(body) {
    overflow: hidden;
  }

  .quetzal-shell {
    display: flex;
    flex-direction: column;
    height: 100vh;
    background: #0e0e10;
    color: #e7e4ec;
  }

  /* ── Top bar ─────────────────────────────── */
  .top-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1.25rem;
    height: 52px;
    flex-shrink: 0;
    border-bottom: 1px solid rgba(71, 71, 78, 0.4);
    background: rgba(14, 14, 16, 0.95);
    backdrop-filter: blur(12px);
    z-index: 10;
  }

  .back-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #acaab1;
    text-decoration: none;
    padding: 0.4rem 0.75rem;
    border: 1px solid rgba(71, 71, 78, 0.4);
    border-radius: 9999px;
    transition: color 0.2s, border-color 0.2s;
  }
  .back-btn:hover {
    color: #7bd0ff;
    border-color: rgba(123, 208, 255, 0.4);
  }

  .top-bar-title {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-weight: 700;
    font-size: 0.9rem;
    color: #e7e4ec;
  }

  .icon-primary { color: #7bd0ff; }

  .top-bar-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #7bd0ff;
    background: rgba(123, 208, 255, 0.08);
    border: 1px solid rgba(123, 208, 255, 0.2);
    padding: 0.2rem 0.6rem;
    border-radius: 9999px;
  }

  /* ── Stage (iframe + sidebar) ────────────── */
  .stage {
    display: flex;
    flex: 1;
    overflow: hidden;
  }

  /* ── Game iframe ─────────────────────────── */
  .game-frame-wrapper {
    flex: 1;
    position: relative;
    background: #000;
  }

  .game-frame {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
  }

  /* ── Sidebar ─────────────────────────────── */
  .sidebar {
    width: 300px;
    flex-shrink: 0;
    border-left: 1px solid rgba(71, 71, 78, 0.4);
    background: #0e0e10;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: rgba(71, 71, 78, 0.4) transparent;
  }

  .sidebar-inner {
    padding: 1.5rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .sidebar-section {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .sidebar-heading {
    font-size: 0.85rem;
    font-weight: 700;
    color: #e7e4ec;
    border-bottom: 1px solid rgba(71, 71, 78, 0.3);
    padding-bottom: 0.5rem;
    margin-bottom: 0.25rem;
  }

  .sidebar-subheading {
    font-size: 0.78rem;
    font-weight: 600;
    color: #e7e4ec;
  }

  .sidebar-body {
    font-size: 0.72rem;
    line-height: 1.6;
    color: #acaab1;
  }

  .sidebar-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .sidebar-list li {
    font-size: 0.68rem;
    line-height: 1.55;
    color: #acaab1;
    padding-left: 0.85rem;
    position: relative;
  }

  .sidebar-list li::before {
    content: '›';
    position: absolute;
    left: 0;
    color: #7bd0ff;
    font-weight: 700;
  }

  .sidebar-list code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.62rem;
    color: #7bd0ff;
    background: rgba(123, 208, 255, 0.08);
    padding: 0.1rem 0.3rem;
    border-radius: 3px;
  }

  /* Architecture badges */
  .arch-badge {
    display: inline-block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #7bd0ff;
    border: 1px solid rgba(123, 208, 255, 0.25);
    padding: 0.15rem 0.5rem;
    border-radius: 9999px;
    width: fit-content;
  }

  .arch-badge--node {
    color: #86efac;
    border-color: rgba(134, 239, 172, 0.25);
  }

  .arch-badge--db {
    color: #fbbf24;
    border-color: rgba(251, 191, 36, 0.25);
  }

  .arch-badge--flow {
    color: #c3b1e1;
    border-color: rgba(195, 177, 225, 0.25);
  }

  /* Data flow diagram */
  .flow {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.25rem;
  }

  .flow-step {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.62rem;
    color: #e7e4ec;
    background: rgba(31, 31, 36, 0.8);
    border: 1px solid rgba(71, 71, 78, 0.4);
    padding: 0.25rem 0.5rem;
    border-radius: 6px;
  }

  .flow-arrow {
    font-size: 0.6rem;
    color: #acaab1;
    white-space: nowrap;
  }

  /* Tags */
  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #acaab1;
    background: rgba(31, 31, 36, 0.8);
    border: 1px solid rgba(71, 71, 78, 0.3);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
  }

  /* ── Responsive ──────────────────────────── */
  @media (max-width: 768px) {
    :global(body) {
      overflow: auto;
    }

    .quetzal-shell {
      height: auto;
      min-height: 100vh;
    }

    .stage {
      flex-direction: column;
      overflow: visible;
    }

    .game-frame-wrapper {
      width: 100%;
      aspect-ratio: 16 / 9;
      flex: none;
    }

    .sidebar {
      width: 100%;
      border-left: none;
      border-top: 1px solid rgba(71, 71, 78, 0.4);
    }
  }
</style>
